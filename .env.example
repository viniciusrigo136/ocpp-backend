# Porta do servidor (Railway/Render define automaticamente via PORT)
PORT=3000

# URL do webhook da Lovable (para enviar eventos em tempo real)
LOVABLE_WEBHOOK_URL=https://seu-projeto.lovable.app/api/ocpp-events

# Token de autenticação da API REST
API_SECRET_TOKEN=seu-token-secreto-aqui

# Habilitar logs detalhados (true/false)
DEBUG=true
